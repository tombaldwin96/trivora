{
  "cli": {
    "version": ">= 16.32.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_JS_ENGINE": "jsc",
        "EAS_RESTORE_CACHE": "0"
      },
      "cache": {
        "key": "jsc-ios-v8"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
