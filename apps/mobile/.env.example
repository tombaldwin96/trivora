# Supabase (required)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: for remote dev with tunnel (avoids "Cannot read properties of undefined (reading 'body')")
